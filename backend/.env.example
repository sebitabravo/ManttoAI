APP_NAME=ManttoAI Predictive Maintenance API
APP_ENV=development
API_PREFIX=
DATABASE_URL=mysql+pymysql://root:__REPLACE_WITH_MYSQL_ROOT_PASSWORD__@mysql:3306/manttoai_db
DATABASE_AUTO_INIT=true
SECRET_KEY=__REPLACE_WITH_SECRET_KEY__
MQTT_BROKER_HOST=mosquitto
MQTT_BROKER_PORT=1883
MQTT_USERNAME=__REPLACE_WITH_MQTT_USERNAME__
MQTT_PASSWORD=__REPLACE_WITH_MQTT_PASSWORD__
MQTT_BASE_TOPIC=manttoai/equipo
MQTT_ENABLED=true
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_TO_EMAIL=
ENABLE_PREDICTION_SCHEDULER=true
PREDICTION_INTERVAL_SECONDS=300
PREDICTION_SCHEDULER_MAX_WORKERS=4

# Seed demo (usado por scripts/seed_db.py)
SEED_ADMIN_NAME=Admin ManttoAI
SEED_ADMIN_EMAIL=admin@manttoai.local
SEED_ADMIN_PASSWORD=__REPLACE_WITH_ADMIN_PASSWORD__
SEED_RESET_ADMIN_PASSWORD=false
SEED_ALLOW_NON_DEV=false
