APP_NAME=ManttoAI Predictive Maintenance API
APP_ENV=development
API_PREFIX=
DATABASE_URL=mysql+pymysql://root:__REPLACE_WITH_MYSQL_ROOT_PASSWORD__@mysql:3306/manttoai_db
DATABASE_AUTO_INIT=true
SECRET_KEY=__REPLACE_WITH_SECRET_KEY__
MQTT_BROKER_HOST=mosquitto
MQTT_BROKER_PORT=1883
MQTT_USERNAME=__REPLACE_WITH_MQTT_USERNAME__
MQTT_PASSWORD=__REPLACE_WITH_MQTT_PASSWORD__
MQTT_BASE_TOPIC=manttoai/equipo
MQTT_ENABLED=true
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@manttoai.local
SMTP_TO_EMAIL=alertas@manttoai.local
SMTP_USE_STARTTLS=false
SMTP_REQUIRE_AUTH=false
ENABLE_PREDICTION_SCHEDULER=true
PREDICTION_INTERVAL_SECONDS=30
PREDICTION_SCHEDULER_MAX_WORKERS=4
ML_AUTO_TRAIN_ON_MISSING=true
# Simulador IoT para demo (genera lecturas MQTT automáticas sin hardware)
# Activar con SIMULATOR_ENABLED=true para demos
SIMULATOR_ENABLED=false
SIMULATOR_INTERVAL_SECONDS=30
# Orígenes CORS permitidos (separados por coma).
# En desarrollo: dejar el valor por defecto.
# En producción: reemplazar con el dominio real del frontend.
# Ejemplo: CORS_ALLOWED_ORIGINS=https://manttoai.tudominio.com
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Seed demo (usado por scripts/seed_db.py)
SEED_ADMIN_NAME=Admin ManttoAI
SEED_ADMIN_EMAIL=admin@manttoai.local
SEED_ADMIN_PASSWORD=__REPLACE_WITH_ADMIN_PASSWORD__
SEED_RESET_ADMIN_PASSWORD=false
SEED_TECNICO_NAME=Tecnico ManttoAI
SEED_TECNICO_EMAIL=tecnico@manttoai.local
SEED_TECNICO_PASSWORD=__REPLACE_WITH_TECNICO_PASSWORD__
SEED_RESET_TECNICO_PASSWORD=false
SEED_ALLOW_NON_DEV=false
